pipeline {
    agent any

    stages {
        stage('clone') {
            steps {
                git branch: 'main', url: 'https://github.com/shitesh372/cicdproject.git'
            }
        } 

 stage('build') {
            steps {
                sh 'docker build -t shitesh3796/pythonimage -f dockerfile .'
            }
        }
stage('push') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'mytoken', passwordVariable: 'password', usernameVariable: 'username')]) {
  sh '''echo $password | docker login -u $username --password-stdin
docker push shitesh3796/pythonimage'''  
}
        }
}
stage('install trivy') {
            steps {
               sh '''sudo apt-get install wget gnupg
wget -qO - https://aquasecurity.github.io/trivy-repo/deb/public.key | gpg --dearmor | sudo tee /usr/share/keyrings/trivy.gpg > /dev/null
echo "deb [signed-by=/usr/share/keyrings/trivy.gpg] https://aquasecurity.github.io/trivy-repo/deb generic main" | sudo tee -a /etc/apt/sources.list.d/trivy.list
sudo apt-get update
sudo apt-get install trivy'''
            }
        }
stage('Trivy Scan') {
    steps {
        sh '''
            trivy image shitesh3796/pythonimage
        '''
    }
}
}
}
